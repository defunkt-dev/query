<query-client-provider>
  <query/result options=() => ({
    queryKey: ["todos"],
    queryFn: async () => ["inline-never-called-on-server"],
    staleTime: Infinity,
  })/>
  <div data-testid="status">${result.status}</div>
  <div data-testid="data">${JSON.stringify(result.data ?? null)}</div>
</query-client-provider>
